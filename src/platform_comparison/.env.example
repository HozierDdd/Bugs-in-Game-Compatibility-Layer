# OpenAI-compatible LLM settings for src/cr_characteristics_pipeline.
# Replace the placeholder with your real API key before running calibrate.
# NOTE: the paper's ten-item CR content coding (RQ1) was run with
# Claude Opus 4.8 (model id: claude-opus-4-8) through an OpenAI-compatible
# endpoint; set LLM_API_BASE_URL to your provider's endpoint.
OPENAI_API_KEY=your-api-key-here
LLM_API_BASE_URL=https://api.openai.com/v1
LLM_MODEL=claude-opus-4-8
